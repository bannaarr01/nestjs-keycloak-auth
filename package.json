{
  "name": "nestjs-keycloak-auth",
  "version": "1.0.0",
  "description": "Keycloak authentication and authorization module for NestJS",
  "author": "B. Joshua Adedigba",
  "contributors": [
    {
      "name": "B. Joshua Adedigba",
      "email": "tbannaarr@gmail.com",
      "url": "https://github.com/bannaarr01"
    }
  ],
  "license": "MIT",
  "scripts": {
    "start:dev": "tsc -w",
    "clean": "rimraf dist",
    "build": "tsc",
    "release": "release-it",
    "release:alpha": "release-it --preReleaseId=alpha --npm.tag=next --github.preRelease",
    "format": "prettier src --write",
    "lint": "eslint src",
    "prepare": "husky"
  },
  "keywords": [
    "nestjs",
    "keycloak",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bannaarr01/nestjs-keycloak-auth"
  },
  "bugs": "https://github.com/bannaarr01/nestjs-keycloak-auth/issues",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "dist/index.d.ts": [
        "dist/index.d.ts"
      ],
      "*": [
        "dist/*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*"
  },
  "peerDependencies": {
    "@nestjs/axios": ">=3.0.0",
    "@nestjs/common": ">=6.0.0 <12.0.0",
    "@nestjs/core": ">=6.0.0 <12.0.0",
    "@nestjs/graphql": ">=6",
    "axios": ">=1.0.0"
  },
  "devDependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.6",
    "@nestjs/core": "^11.0.6",
    "@nestjs/graphql": "^13.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^18.19.23",
    "axios": "^1.7.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cpr": "3.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "graphql": "^16.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "3.2.5",
    "reflect-metadata": "0.2.1",
    "release-it": "17.1.1",
    "rimraf": "3.0.2",
    "rxjs": "7.8.1",
    "ts-node": "10.8.2",
    "typescript": "5.4.2",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependenciesMeta": {
    "@nestjs/graphql": {
      "optional": true
    },
    "@nestjs/axios": {
      "optional": false
    },
    "axios": {
      "optional": false
    }
  },
  "volta": {
    "node": "21.7.1"
  },
  "lint-staged": {
    "**/*.ts": [
      "prettier --write",
      "eslint"
    ]
  }
}
