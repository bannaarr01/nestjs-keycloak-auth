{
  "name": "nestjs-keycloak-auth",
  "version": "1.0.1",
  "description": "Keycloak authentication and authorization module for NestJS",
  "author": "B. Joshua Adedigba",
  "contributors": [
    {
      "name": "B. Joshua Adedigba",
      "email": "tbannaarr@gmail.com",
      "url": "https://github.com/bannaarr01"
    }
  ],
  "license": "MIT",
  "scripts": {
    "start:dev": "tsc -w",
    "clean": "rimraf dist",
    "build": "tsc",
    "test": "jest",
    "test:cov": "jest --coverage --runInBand",
    "release": "release-it",
    "release:alpha": "release-it --preReleaseId=alpha --npm.tag=next --github.preRelease",
    "format": "prettier src --write",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepare": "husky"
  },
  "keywords": [
    "nestjs",
    "nest",
    "keycloak",
    "nest-keycloak",
    "keycloak-nest",
    "typescript",
    "authentication",
    "authorization",
    "oauth2",
    "openid-connect",
    "oidc",
    "rbac",
    "guard",
    "uma",
    "multi-tenant",
    "jwt",
    "sso",
    "access-control"
  ],
  "homepage": "https://github.com/bannaarr01/nestjs-keycloak-auth#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/bannaarr01/nestjs-keycloak-auth"
  },
  "bugs": "https://github.com/bannaarr01/nestjs-keycloak-auth/issues",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "dist/index.d.ts": [
        "dist/index.d.ts"
      ],
      "*": [
        "dist/*"
      ]
    }
  },
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*"
  },
  "peerDependencies": {
    "@nestjs/axios": ">=3.0.0",
    "@nestjs/common": ">=10.0.0 <12.0.0",
    "@nestjs/core": ">=10.0.0 <12.0.0",
    "axios": ">=1.0.0"
  },
  "devDependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.6",
    "@nestjs/core": "^11.0.6",
    "@nestjs/graphql": "^13.0.2",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.23",
    "axios": "^1.7.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "cpr": "3.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "graphql": "^16.10.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^15.5.2",
    "prettier": "3.2.5",
    "reflect-metadata": "0.2.1",
    "release-it": "^19.2.4",
    "rimraf": "6.1.3",
    "rxjs": "7.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "10.8.2",
    "typescript": "5.4.2",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependenciesMeta": {
    "@nestjs/axios": {
      "optional": false
    },
    "axios": {
      "optional": false
    }
  },
  "volta": {
    "node": "21.7.1"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint"
    ]
  },
  "overrides": {
    "release-it": {
      "undici": "^7.0.0"
    }
  }
}
