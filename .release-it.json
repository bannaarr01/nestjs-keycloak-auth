{
  "git": {
    "commitMessage": "chore: release ${version}",
    "tagName": "v${version}",
    "commitArgs": ["--no-verify"]
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": ["npm run lint", "npm run test:cov"],
    "after:bump": ["npm run clean", "npm run build"]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "angular",
      "infile": "CHANGELOG.md"
    }
  }
}
